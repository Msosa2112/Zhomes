{
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/sync",
      "schedule": "0 22 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
